# ── App ──
APP_NAME=NoteKey API
DEBUG=true
PORT=8000

# ── Database (Supabase Postgres or any Postgres) ──
DATABASE_URL=postgresql+asyncpg://notekey:notekey@localhost:5432/notekey

# ── Storage ──
# "local" for dev (saves to UPLOAD_DIR), "supabase" for production
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# Supabase Storage (required when STORAGE_BACKEND=supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=uploads

# ── Upload limits ──
MAX_UPLOAD_SIZE_MB=100

# ── CORS ──
# Explicit origins (JSON array)
CORS_ORIGINS=["http://localhost:3000"]
# Regex to match all Vercel preview URLs automatically
CORS_ORIGIN_REGEX=https://.*\.vercel\.app
